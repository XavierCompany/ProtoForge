{
  "servers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_token}"
      }
    },
    "azure": {
      "command": "azd",
      "args": ["mcp"],
      "env": {}
    }
  },
  "inputs": [
    {
      "id": "github_token",
      "type": "promptString",
      "description": "GitHub Personal Access Token (or set GITHUB_PERSONAL_ACCESS_TOKEN env var)",
      "password": true
    }
  ]
}
