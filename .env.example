# ProtoForge - Multi-Agent Orchestrator
# Copy this to .env and fill in your values

# === LLM Provider ===
# Default provider (anthropic recommended — Claude Opus 4.6)
# Options: anthropic, azure_ai_foundry, openai, google
DEFAULT_LLM_PROVIDER=anthropic

# Anthropic (Claude Opus 4.6 — default, highest quality reasoning)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4.6
# Alternative: ANTHROPIC_MODEL=claude-sonnet-4.6

# Azure AI Foundry (best quality/cost/throughput on Azure)
AZURE_AI_FOUNDRY_ENDPOINT=https://your-project.services.ai.azure.com
AZURE_AI_FOUNDRY_MODEL=gpt-5.3-codex
AZURE_AI_FOUNDRY_API_VERSION=2026-01-01

# OpenAI (GPT-4o for general, Codex 5.3 for code-heavy tasks)
OPENAI_API_KEY=
OPENAI_MODEL=codex-5.3
# Alternative: OPENAI_MODEL=gpt-4o

# Google (Gemini Pro 3.1 — latest, Gemini Pro 3.0)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-pro-3.1
# Alternative: GOOGLE_MODEL=gemini-pro-3.0

# === Authentication ===
# Use "azure_default" for DefaultAzureCredential, or "api_key" for direct keys
AUTH_METHOD=azure_default

# === Server ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# === Observability ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO

# === MCP ===
MCP_SERVER_PORT=8081
MCP_SKILLS_DIR=./skills

# === Agent Registry ===
REGISTRY_PATH=./registry_data
