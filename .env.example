# ProtoForge - Multi-Agent Orchestrator
# Copy this to .env and fill in your values

# === LLM Provider (pick one or more) ===
# Azure AI Foundry (recommended)
AZURE_AI_FOUNDRY_ENDPOINT=https://your-project.services.ai.azure.com
AZURE_AI_FOUNDRY_MODEL=gpt-5.1
AZURE_AI_FOUNDRY_API_VERSION=2025-01-01

# OpenAI Direct
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4

# Google
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro

# === Authentication ===
# Use "azure_default" for DefaultAzureCredential, or "api_key" for direct keys
AUTH_METHOD=azure_default

# === Server ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# === Observability ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO

# === MCP ===
MCP_SERVER_PORT=8081
MCP_SKILLS_DIR=./skills

# === Agent Registry ===
REGISTRY_PATH=./registry_data
